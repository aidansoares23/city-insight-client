# Google OAuth 2.0 client ID — required for sign-in to work
# Get yours at: https://console.cloud.google.com/ → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Set to "false" to hide the Ask AI page and nav link (default: true / enabled)
# The backend must also have AI enabled; the app falls back gracefully if not.
# VITE_AI_ENABLED=true
